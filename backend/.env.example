# Copy this file to `.env` and fill in locally. NEVER commit `.env`.
# The server uses these ONLY if the request has no bring-your-own key.
# For the PUBLIC deploy, set only GEMINI_API_KEY (free tier). Keep ANTHROPIC local.

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
TAVILY_API_KEY=

# Comma-separated allowed frontend origins (set to your Vercel URL in prod).
ALLOWED_ORIGIN=http://localhost:5173
